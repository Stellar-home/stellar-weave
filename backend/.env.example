DATABASE_URL=postgres://postgres:postgres@localhost:5432/weave
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# v2 contract IDs — see contracts/profile-registry/DEPLOYMENT.md and
# contracts/follow-graph/DEPLOYMENT.md for the deployed addresses after redeploy.
PROFILE_REGISTRY_CONTRACT_ID=REPLACE_WITH_V2_PROFILE_REGISTRY_CONTRACT_ID
# Ledger to start from on first run.
# 0 = tip minus 1000 ledgers (~83 min lookback).
# Set to the v2 ProfileRegistry deployment ledger for a full historical ingest.
START_LEDGER=0
POLL_INTERVAL_SECONDS=5
PORT=3001
